# ── Wallet / Identity ─────────────────────────────────────────────────────────
# 64-character hex string (no 0x prefix), your node operator wallet private key
NODE_PRIVATE_KEY=0xabc123def456abc123def456abc123def456abc123def456abc123def456abcd

# ── Blockchain / RPC ──────────────────────────────────────────────────────────
# Polygon Amoy (formerly Mumbai) testnet RPC endpoint
# Get a free key at https://www.alchemy.com or https://infura.io
RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_ALCHEMY_KEY_HERE

# ── Smart Contract Addresses (deploy via Hardhat, then paste here) ────────────
JOB_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000
MODEL_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
STAKE_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# ── Backend WebSocket ─────────────────────────────────────────────────────────
# Coordinator WebSocket endpoint that broadcasts job events in real-time
COORDINATOR_WS_URL=wss://your-backend.example.com/ws/jobs

# ── IPFS ──────────────────────────────────────────────────────────────────────
# Public or private IPFS gateway for fetching model/data CIDs
IPFS_GATEWAY=https://ipfs.io/ipfs

# ── Local Paths ───────────────────────────────────────────────────────────────
# Directory where downloaded ONNX/TFLite models are cached locally
MODEL_CACHE_DIR=./models_cache

# ── Logging ───────────────────────────────────────────────────────────────────
# Set to DEBUG for verbose output during development, INFO for production
LOG_LEVEL=INFO
